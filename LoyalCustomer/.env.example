# LoyalCustomer Service - Variables de entorno requeridas
# Copia este archivo como .env y llena los valores reales

SERVER_PORT=8093

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=loyalty
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# Configuracion del programa de lealtad
LOYALTY_POINTS_PER_PURCHASE=10
LOYALTY_REWARD_THRESHOLD=100
