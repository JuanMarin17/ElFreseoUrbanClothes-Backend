# Returns Service - Variables de entorno requeridas
# Copia este archivo como .env y llena los valores reales

SERVER_PORT=8092

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=returns
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# URL del servicio de ordenes
ORDER_SERVICE_URL=http://localhost:8087
