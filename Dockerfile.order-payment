FROM maven:3.9-eclipse-temurin-21-alpine AS build
WORKDIR /build
COPY common-request-context-starter ./common-request-context-starter
RUN cd common-request-context-starter && mvn install -DskipTests -q
COPY OrderPayment ./OrderPayment
WORKDIR /build/OrderPayment
RUN mvn package -DskipTests -q

FROM eclipse-temurin:21-jre-alpine
WORKDIR /app
COPY --from=build /build/OrderPayment/target/*.jar app.jar
ENTRYPOINT ["java", "-jar", "app.jar"]
