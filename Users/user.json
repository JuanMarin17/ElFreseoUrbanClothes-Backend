    {
      "name": "2. Get Username by ID",
      "item": [
        {
          "name": "✅ Obtener nombre - ID válido existente",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/users/myUserName/{{valid_user_id}}",
              "host": ["{{base_url}}"],
              "path": ["users", "myUserName", "{{valid_user_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Respuesta es string', () => {",
                  "  pm.expect(pm.response.text()).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ Obtener nombre - UUID inexistente",
          "request": {
