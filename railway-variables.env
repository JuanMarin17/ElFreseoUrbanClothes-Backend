# =============================================================================
# VARIABLES DE ENTORNO PARA RAILWAY
# =============================================================================
# Instrucciones:
# 1. En Railway, crea un proyecto y agrega un plugin PostgreSQL.
#    Railway te dará las vars: PGHOST, PGPORT, PGUSER, PGPASSWORD.
#
# 2. Conectate a esa BD y ejecuta el archivo docker/init.sql
#    para crear las 15 bases de datos.
#
# 3. Para cada servicio en Railway:
#    - Root Directory: . (raiz del proyecto)
#    - Dockerfile Path: Dockerfile.<nombre-servicio>
#    - Agrega las variables del servicio correspondiente abajo.
#
# 4. El nombre de cada servicio en Railway DEBE coincidir exactamente
#    con el nombre usado en las URLs .railway.internal, por ejemplo:
#    "auth-service", "users-service", "gateway", etc.
#
# NOTA: Reemplaza <PGHOST>, <PGPORT>, <PGUSER>, <PGPASSWORD>
#       con los valores que Railway genera para tu PostgreSQL.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# SERVICIO: auth-service
# Dockerfile: Dockerfile.auth
# Nombre en Railway: auth-service
# ─────────────────────────────────────────────────────────────────────────────
SERVER_PORT=8082
DB_URL=jdbc:postgresql://<PGHOST>:<PGPORT>/auth
DB_USER=<PGUSER>
DB_PASSWORD=<PGPASSWORD>
SPRING_DATASOURCE_URL=jdbc:postgresql://<PGHOST>:<PGPORT>/auth
SPRING_DATASOURCE_USERNAME=<PGUSER>
SPRING_DATASOURCE_PASSWORD=<PGPASSWORD>
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=5
JWT_SECRET=Wm5N30DT1nFqUmdjrvM4GWqw1utDrSlpdDLyDGa4kBw=
USERS_SERVICE_URL=http://users-service.railway.internal:8083/api/v1
MAIL_USERNAME=vexiomultistore@gmail.com
MAIL_PASSWORD=fqqq kpuc qniw pwkb


